            <PARAM_TEXT width="100%" param_id="$ROOTKEY$"/>
            <POPUP_MENU id="root_key_menu">
                <LOCAL_VARIABLE id="local_index" value="0"/>
                <REPEAT index_list="$TRANSFORM_KEYS$">
                    <MENU_ITEM action_id="root_key_action$local_index$" checked_param_id="root_key_menu_item$local_index$_checked"/>
