            <TEXT value="$text$" v_offset="1" font_size="-2"/>
            <TEXT value="$text$" text_color="#999999" visible="false" id="$id$.high_text" v_offset="1" font_size="-2"/>
            <PARAM_LINK from="$param_id$" to="$id$.high_text.visible" reverse="$reverse$"/>
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_TOGGLE_SWITCH>
    </TEMPLATE>
    <TEMPLATE id="TPL_SCALE_BUTTON" param_id="#UNDEFINED#" text="#UNDEFINED#">
        <IMAGE_PARAM_BUTTON image="Graphics/ScaleRotateButton2.png" images_count="1" positions_count="2" loop="true" auto_focus="false" param_id="$param_id$" id="$id$" layout_type="layer_stack" reset_modifier_key="ctrl" v_offset="$v_offset$" h_offset="$h_offset$" opaque_mouse_mask="true">
            <TEXT value="$text$" v_offset="0" font_size="+2"/>
            <TEXT value="$text$" text_color="#999999" visible="false" id="$id$.high_text" v_offset="0" font_size="+2"/>
            <PARAM_LINK from="$id$.pushed" to="$id$.high_text.visible"/>
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_BUTTON>
    </TEMPLATE>
    <TEMPLATE id="TPL_TRANSPOSE_BUTTON" param_id="#UNDEFINED#" text="#UNDEFINED#">
        <IMAGE_PARAM_BUTTON image="$image$" images_count="1" positions_count="2" loop="true" auto_focus="false" param_id="$param_id$" id="$id$" layout_type="layer_stack" reset_modifier_key="ctrl" v_offset="$v_offset$" h_offset="$h_offset$" opaque_mouse_mask="true">
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_BUTTON>
    </TEMPLATE>
    <TEMPLATE id="TPL_SNAPSHOT_BUTTON" param_id="#UNDEFINED#" text="#UNDEFINED#">
        <IMAGE_PARAM_TOGGLE_SWITCH image="Graphics/snapshot_button.png" auto_focus="false" param_id="$param_id$" id="$id$" layout_type="layer_stack" v_offset="-6" h_offset="-4" opaque_mouse_mask="true">
            <TEXT value="$text$" v_offset="1" font_weight="bold" font_size="+0"/>
            <TEXT value="$text$" text_color="#4c4c4c" visible="false" id="$id$.high_text" v_offset="1" font_weight="bold" font_size="+0"/>
            <PARAM_LINK from="$param_id$" to="$id$.high_text.visible"/>
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_TOGGLE_SWITCH>
