            <TEXT value="$text$" v_offset="1" font_size="-2"/>
            <TEXT value="$text$" text_color="#999999" visible="false" id="$id$.high_text" v_offset="1" font_size="-2"/>
            <PARAM_LINK from="$param_id$" to="$id$.high_text.visible" reverse="$reverse$"/>
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_BUTTON>
    </TEMPLATE>
    <TEMPLATE id="TPL_CUSTOM_BUTTON_METER" param_id="#UNDEFINED#" text="#UNDEFINED#" reverse="false" loop="true">
        <IMAGE_PARAM_METER image="Graphics/switch.png" loop="$loop$" auto_focus="false" param_id="$param_id$" id="$id$" layout_type="layer_stack" reset_modifier_key="ctrl" v_offset="$v_offset$" h_offset="$h_offset$" reverse="$reverse$">
            <TEXT value="$text$" v_offset="1" font_size="-2"/>
            <TEXT value="$text$" text_color="#999999" visible="false" id="$id$.high_text" v_offset="1" font_size="-2"/>
            <PARAM_LINK from="$param_id$" to="$id$.high_text.visible" reverse="$reverse$"/>
            <TEMPLATE_INNER_CONTENT/>
        </IMAGE_PARAM_METER>
    </TEMPLATE>
    <TEMPLATE id="TPL_CUSTOM_TOGGLE" param_id="#UNDEFINED#" text="#UNDEFINED#" reverse="false" loop="true">
