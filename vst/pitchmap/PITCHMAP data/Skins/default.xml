            <TEXT value="$text$" v_offset="1" font_weight="bold" font_size="+0"/>
            <TEXT value="$text$" text_color="#4c4c4c" visible="false" id="$id$.high_text" v_offset="1" font_weight="bold" font_size="+0"/>
