    <!-- PROCESS COLUMN -->
    <ROW spacing="8"		h_position="195" v_position="336" width="449" height="109" v_align="top">
        <COLUMN spacing="4" v_align="top">
            <IMAGE_PARAM_KNOB image="Graphics/ball_slider_magenta.png" param_id="$THRESHOLD$" images_count="129" reset_modifier_key="ctrl" id="THRESHOLD_ball" opaque_mouse_mask="true">
                <TOOLTIP text="This sets the pitch deviation from the closest semitone (or from the note pitch, if GLOBAL) that triggers pitch correction. Higher values correct only notes that are far off their actual pitch, lower values are more strict. Higher values also preserve transients better."/>
            </IMAGE_PARAM_KNOB>

            <PARAM id="threshold_type" type="enumeration" enum_values="THRESHOLD;G. THRES"/>
            <PARAM_CONNECTION id1="$GLOBAL_THRES$" id2="threshold_type"/>
            <LAYER_STACK id="THRESHOLD_label_container" height="16">
                <IMAGE_PARAM_BUTTON image="Graphics/threshold_button.png" v_offset="-1" h_offset="0" param_id="$GLOBAL_THRES$" images_count="1" positions_count="2" id="THRESHOLD_push_button" layout_type="layer_stack" display="true" height="16" opaque_mouse_mask="true">
                    <PARAM_TEXT param_id="threshold_type" width="100%" height="100%" h_offset="1" id="THRESHOLD_text"/>
                    <PARAM_TEXT param_id="threshold_type" width="100%" height="100%" h_offset="1" text_color="#999999" id="THRESHOLD_text_hi" visible="false"/>
                    <PARAM_LINK from="THRESHOLD_text.visible" to="THRESHOLD_text_hi.visible" reverse="true"/>
                    <PARAM_LINK from="THRESHOLD_push_button.pushed" to="THRESHOLD_text.visible" reverse="true"/>
                </IMAGE_PARAM_BUTTON>
