<?xml version="1.0" encoding="utf-8" ?>
<SKIN author="Blue Cat Audio" name="PITCHMAP" background_image="Graphics/background.png" layout_type="layer_stack" font_face="Arial" text_color="#6c6c6c" font_size="13" right_click_action="" refresh_time_ms="20">

    <!-- include params mapping -->
